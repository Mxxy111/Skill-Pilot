{
  "name": "skillpilot-local",
  "version": "0.3.0",
  "description": "Local operations center for managing AI Agent Skills across Claude, Codex, OpenClaw, Gemini, Cursor and custom sources",
  "type": "module",
  "bin": {
    "skillpilot": "./bin/skillpilot.js",
    "quiver": "./bin/quiver.js"
  },
  "files": [
    "bin/",
    "src/",
    "ui/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sam-blakeman/quiver.git"
  },
  "homepage": "https://github.com/sam-blakeman/quiver",
  "scripts": {
    "start": "node src/cli.js",
    "ui": "node src/cli.js ui",
    "test": "node --test",
    "check": "node --check src/cli.js && node --check src/routes.js && node --check src/server.js && node --check src/core/automation.js && node --check src/core/bulk.js && node --check ui/app.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "skill-manager",
    "codex",
    "openclaw",
    "ollama",
    "quiver",
    "cli"
  ],
  "author": "Sam",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.3.0",
    "multer": "^2.2.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "playwright-core": "^1.61.1"
  }
}
