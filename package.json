{
  "name": "skillpilot-local",
  "version": "0.8.0",
  "description": "Local operations center for managing AI Agent Skills across Claude, Codex, OpenClaw, Gemini, Cursor and custom sources",
  "type": "module",
  "main": "desktop/main.js",
  "bin": {
    "skillpilot": "./bin/skillpilot.js",
    "quiver": "./bin/quiver.js"
  },
  "files": [
    "bin/",
    "desktop/",
    "scripts/",
    "src/",
    "ui/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Mxxy111/Skill-Pilot.git"
  },
  "homepage": "https://github.com/Mxxy111/Skill-Pilot",
  "bugs": {
    "url": "https://github.com/Mxxy111/Skill-Pilot/issues"
  },
  "scripts": {
    "start": "node src/cli.js",
    "ui": "node src/cli.js ui",
    "desktop": "electron .",
    "smoke:desktop": "node scripts/desktop-smoke.mjs",
    "icon:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-icon.ps1",
    "pack:win": "electron-builder --win dir --x64",
    "dist:win": "npm run icon:win && electron-builder --win nsis portable --x64",
    "test": "node --test",
    "check": "node --check desktop/main.js && node --check desktop/policies.js && node --check src/cli.js && node --check src/routes.js && node --check src/server.js && node --check src/core/app-updates.js && node --check src/core/automation.js && node --check src/core/bulk.js && node --check src/core/groups.js && node --check src/core/discovery-service.js && node --check src/core/skills-catalog.js && node --check src/core/github-repository.js && node --check src/core/repository-installer.js && node --check src/core/repository-security.js && node --check src/core/repository-updater.js && node --check ui/app.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "skill-manager",
    "codex",
    "openclaw",
    "ollama",
    "quiver",
    "cli"
  ],
  "author": "Sam",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.3.0",
    "multer": "^2.2.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "playwright-core": "^1.61.1"
  },
  "build": {
    "appId": "io.skillpilot.desktop",
    "productName": "SkillPilot",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "ui/**/*",
      "bin/**/*",
      "docs/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "win": {
      "executableName": "SkillPilot",
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    }
  }
}
